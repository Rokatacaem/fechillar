generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  USER
  PLAYER
  CLUB_ADMIN
  CLUB_DELEGATE
  FEDERATION_ADMIN
  FEDERATION_DELEGATE
  SUPERADMIN
}

enum TournamentScope {
  NATIONAL
  INTERNAL
  EXTERNAL_REFERENCE
}

enum TournamentStatus {
  OPEN
  IN_PROGRESS
  FINISHED
}

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id                 String                 @id @default(uuid())
  name               String?
  email              String                 @unique
  passwordHash       String?
  role               UserRole               @default(USER)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  playerProfile      PlayerProfile?
  createdTournaments Tournament[]             @relation("TournamentCreator")
  assignments        TournamentAssignment[]
  validatedPayments  TournamentRegistration[] @relation("PaymentValidator")
  auditLogs          AuditLog[]               @relation("AuditLogs")
}

model Club {
  id               String          @id @default(uuid())
  slug             String          @unique
  name             String
  address          String?
  city             String?
  legalStatus      String?
  isValidated      Boolean         @default(false)
  logoUrl          String?
  primaryColor     String          @default("#0b1120")
  secondaryColor   String          @default("#10b981")
  monthlyPlayerFee Float           @default(0)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  financeRecords   FinanceRecord[]
  players          PlayerProfile[]
  tournaments      Tournament[]
}

model PlayerProfile {
  id               String                   @id @default(uuid())
  userId           String                   @unique
  tenantId         String?
  rut              String?                  @unique
  federationId     String?                  @unique
  photoUrl         String?
  birthDate        DateTime?
  gender           String?
  balance          Float                    @default(0)
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  matchAway        Match[]                  @relation("AwayPlayer")
  matchHome        Match[]                  @relation("HomePlayer")
  matchWinner      Match[]                  @relation("WinnerPlayer")
  club             Club?                    @relation(fields: [tenantId], references: [id])
  user             User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rankings         Ranking[]
  registrations    TournamentRegistration[]
  transferRequests TransferRequest[]
}

model Tournament {
  id            String                   @id @default(uuid())
  name          String
  description   String?
  bannerUrl     String?
  startDate     DateTime
  endDate       DateTime?
  location      String?
  discipline    String
  modality      String?
  category      String
  status        TournamentStatus         @default(OPEN)
  scope         TournamentScope          @default(INTERNAL)
  tenantId      String?
  createdById   String?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  matches       Match[]
  hostClub      Club?                    @relation(fields: [tenantId], references: [id])
  creator       User?                    @relation("TournamentCreator", fields: [createdById], references: [id])
  photos        TournamentPhoto[]
  registrations TournamentRegistration[]
  assignments   TournamentAssignment[]
}

model TournamentPhoto {
  id           String     @id @default(uuid())
  url          String
  caption      String?
  tournamentId String
  createdAt    DateTime   @default(now())
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
}

model Match {
  id           String         @id @default(uuid())
  tournamentId String
  round        Int
  matchOrder   Int            @default(0)
  tableNumber  String?
  matchTime    DateTime?
  matchDistance Int?
  homePlayerId String
  awayPlayerId String?
  winnerId     String?
  homeScore    Int?
  awayScore    Int?
  innings      Int?           @default(0)
  isWO         Boolean        @default(false)
  createdAt    DateTime       @default(now())
  awayPlayer   PlayerProfile? @relation("AwayPlayer", fields: [awayPlayerId], references: [id])
  homePlayer   PlayerProfile  @relation("HomePlayer", fields: [homePlayerId], references: [id])
  tournament   Tournament     @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  winner       PlayerProfile? @relation("WinnerPlayer", fields: [winnerId], references: [id])
}

model TransferRequest {
  id          String        @id @default(uuid())
  playerId    String
  fromClubId  String
  toClubId    String
  status      String        @default("PENDING")
  requestedAt DateTime      @default(now())
  resolvedAt  DateTime?
  player      PlayerProfile @relation(fields: [playerId], references: [id])
}

model Ranking {
  id           String        @id @default(uuid())
  playerId     String
  discipline   String
  category     String
  points       Int           @default(0)
  rankPosition Int?
  average      Float?
  updatedAt    DateTime      @updatedAt
  player       PlayerProfile @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, discipline, category])
}

model FinanceRecord {
  id          String    @id @default(uuid())
  tenantId    String?
  playerId    String?
  amount      Float
  type        String
  category    String?
  status      String    @default("PENDING")
  description String?
  dueDate     DateTime?
  paidAt      DateTime?
  createdAt   DateTime  @default(now())
  club        Club?     @relation(fields: [tenantId], references: [id])
}

model TransparencyDocument {
  id         String   @id @default(uuid())
  title      String
  type       String
  url        String
  uploadDate DateTime @default(now())
  year       Int
}

model TournamentRegistration {
  id            String             @id @default(uuid())
  tournamentId  String
  playerId      String
  registeredAt  DateTime           @default(now())
  paid          Boolean            @default(false)
  paymentStatus String             @default("PENDING")
  amountPaid    Float?
  paymentRef    String?
  paidAt        DateTime?
  validatorId   String?
  registeredPoints Int             @default(0)
  status        RegistrationStatus @default(PENDING)
  player        PlayerProfile      @relation(fields: [playerId], references: [id], onDelete: Cascade)
  tournament    Tournament         @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  validator     User?              @relation("PaymentValidator", fields: [validatorId], references: [id])

  @@unique([tournamentId, playerId])
}

model TournamentAssignment {
  id           String     @id @default(uuid())
  tournamentId String
  userId       String
  assignedAt   DateTime   @default(now())
  permissions  String     @default("READ")

  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, userId])
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  targetId  String?
  userId    String
  details   String?
  createdAt DateTime @default(now())
  user      User     @relation("AuditLogs", fields: [userId], references: [id], onDelete: Cascade)
}
